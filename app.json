{
  "expo": {
    "name": "Meridian",
    "slug": "meridian",
    "scheme": "meridian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#101E3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meridian.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Meridian uses your location to show you people nearby."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#101E3B"
      },
      "package": "com.meridian.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-image-picker",
      "expo-notifications",
      ["expo-location", {
        "locationWhenInUsePermission": "Meridian uses your location to show you people nearby."
      }]
    ],
    "extra"{
  "e    "eas": {
        "projectId": "bb5d7b96-12ed-482a-b4c8-1145df892296"
      }
    }
  }
}
