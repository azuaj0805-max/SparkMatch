{
  "expo": {
    "name": "Meridian",
    "slug": "meridian",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#101E3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meridian.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101E3B"
      },
      "package": "com.meridian.app"
    },
    "plugins": [
      "expo-image-picker",
      "expo-notifications"
    ]
  }
}
