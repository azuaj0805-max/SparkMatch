{
  "expo": {
    "name": "Meridian",
    "slug": "meridian",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#101E3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meridian.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Meridian uses your location to show you people nearby."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101E3B"
      },
      "package": "com.meridian.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Meridian uses your location to show you people nearby."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bb5d7b96-12ed-482a-b4c8-1145df892296"
      }
    }
  }
}
