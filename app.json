{
  "expo": {
    "name": "Meridian",
    "slug": "meridian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#101E3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meridian.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Meridian uses your location to show you people nearby."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101E3B"
      },
      "package": "com.meridian.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Meridian uses your location to show you people nearby."
        }
      ]
    ]
  {
}
